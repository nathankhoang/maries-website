# Copy to .env.local for `vercel dev`, and set the same key in the Vercel
# dashboard (Project → Settings → Environment Variables) for production.
# Get a key at https://console.anthropic.com — then set a hard monthly
# spend cap there so a leaked endpoint can't run up an unbounded bill.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Azure AI Speech — real neural Vietnamese/English voice (/api/tts).
# Create a "Speech service" resource in the Azure portal; copy KEY 1 and the
# resource Region (e.g. eastus). If unset, the app falls back to the basic
# browser voice automatically.
AZURE_SPEECH_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AZURE_SPEECH_REGION=eastus
