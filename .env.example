# Copy to .env.local for `vercel dev`, and set the same keys in the Vercel
# dashboard (Project → Settings → Environment Variables) for production.

# Claude API — powers the AI translator (/api/translate).
# Get a key at https://console.anthropic.com — then set a hard monthly
# spend cap there so a leaked endpoint can't run up an unbounded bill.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Postgres connection (auto-injected by the Neon integration on Vercel).
# For local `vercel dev`, run `vercel env pull .env.local` to fetch it.
POSTGRES_URL=postgres://user:password@host/db?sslmode=require

# Admin CMS (/admin) — lets Marie edit the phrasebook.
# ADMIN_PASSWORD: the password Marie logs in with. CHANGE THIS to a strong
# value in the Vercel dashboard; never commit the real one.
ADMIN_PASSWORD=change-me-to-a-strong-password
# ADMIN_SESSION_SECRET: random string used to sign the login session cookie.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=replace-with-a-long-random-hex-string
